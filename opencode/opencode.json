{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["~/.config/opencode/AGENTS.md"],
  "permission": {
    "bash": {
      "*": "ask",        // Default: prompt for other bash commands
      "rm *": "deny", 
      "git *": "deny",
      "gh *": "deny",
      "ls *": "allow",
      "grep": "allow",
      "bun": "allow",
      "bunx": "allow",
      "head": "allow",
      "tail": "allow",
      "cd": "allow",
      "file": "allow",
    }
  }
}
